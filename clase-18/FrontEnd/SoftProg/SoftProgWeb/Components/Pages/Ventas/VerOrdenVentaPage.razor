@page "/VerOrdenVenta"
@attribute [Authorize(Roles = "Empleado,Admin,Cliente")]

<TituloPaginaComponent Texto="Detalle de la orden de venta" />

<div class="card border" data-testid="order-detail-page">
    <div class="card-header">
        <h5 class="card-title mb-0">Informacion de la orden</h5>
    </div>
    <div class="card-body">
        <div class="mb-3 row">
            <label for="idOrden" class="col-sm-2 col-form-label">ID orden:</label>
            <div class="col-sm-3">
                <input id="idOrden" class="form-control" @bind="IdOrden" disabled />
            </div>
        </div>
        <div class="mb-3 row">
            <label for="cliente" class="col-sm-2 col-form-label">Cliente:</label>
            <div class="col-sm-5">
                <input id="cliente" class="form-control" @bind="Cliente" disabled />
            </div>
        </div>
        <div class="mb-3 row">
            <label for="dniCliente" class="col-sm-2 col-form-label">DNI:</label>
            <div class="col-sm-3">
                <input id="dniCliente" class="form-control" @bind="DniCliente" disabled />
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <button class="btn btn-outline-secondary" data-testid="order-detail-back" @onclick="Volver">Volver</button>
</div>

<div class="card border mt-3">
    <div class="card-header">
        <h5 class="card-title mb-0">Detalle de productos</h5>
    </div>
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var linea in LineasOrden)
                {
                    <tr>
                        <td>@linea.ProductoNombre</td>
                        <td>@linea.Cantidad</td>
                        <td>@FormatearMoneda(linea.PrecioUnitario)</td>
                        <td>@FormatearMoneda(linea.SubTotal)</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-end">Subtotal</th>
                    <th>@FormatearMoneda(SubtotalOrden)</th>
                </tr>
                <tr>
                    <th colspan="3" class="text-end">IGV (18%)</th>
                    <th>@FormatearMoneda(IgvOrden)</th>
                </tr>
                <tr>
                    <th colspan="3" class="text-end">Total</th>
                    <th>@FormatearMoneda(TotalOrden)</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>