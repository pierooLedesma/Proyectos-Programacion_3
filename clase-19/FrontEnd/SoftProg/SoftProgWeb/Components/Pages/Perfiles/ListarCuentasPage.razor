@page "/ListarCuentas"
@attribute [Authorize(Roles = "Admin")]

<div class="container py-3" data-testid="accounts-list-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <TituloPaginaComponent Texto="Cuenta de usuario" />
        <BotonVolverAtrasComponent />
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-semibold">Cuentas registradas</h5>
            <button class="btn btn-primary" @onclick="RegistrarCuenta" data-testid="account-create-btn">
                Agregar
            </button>
        </div>
        <div class="card-body">
            <AlertaOperacionComponent Mensaje="@MensajeResultado" Exito="OperacionExitosa" CssAdicional="mb-3" />

            @if (Cuentas.Count == 0)
            {
                <div class="alert alert-secondary border text-center mb-0" data-testid="account-empty-state">
                    <h6 class="fw-semibold">Sin registros por mostrar</h6>
                    <p class="mb-2">Aun no hay datos disponibles para esta seccion.</p>
                    <button class="btn btn-primary" @onclick="RegistrarCuenta" data-testid="account-empty-create-btn">
                        Agregar
                    </button>
                </div>
            }
            else
            {
                <div class="table-responsive border rounded">
                    <table class="table table-hover table-striped align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Usuario</th>
                                <th>Activo</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cuenta in CuentasPaginadas)
                            {
                                <tr data-testid="@($"account-row-{cuenta.Id}")">
                                    <td>@cuenta.Id</td>
                                    <td>@cuenta.UserName</td>
                                    <td>
                                        <input class="form-check-input" type="checkbox" disabled checked="@cuenta.Activo" />
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => ModificarCuenta(cuenta.Id)"
                                                    data-testid="@($"account-edit-{cuenta.Id}")">
                                                Modificar
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => EliminarCuenta(cuenta.Id)"
                                                    data-testid="@($"account-delete-{cuenta.Id}")">
                                                Eliminar
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mt-3">
                    <small class="text-muted">Mostrando @InicioRegistro-@FinRegistro de @TotalRegistros registros</small>
                    <div class="btn-group" role="group" aria-label="Paginacion cuentas">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="PaginaAnterior"
                                disabled="@(PaginaActual == 1)">
                            Anterior
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" disabled>
                            Pagina @PaginaActual de @TotalPaginas
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="PaginaSiguiente"
                                disabled="@(PaginaActual >= TotalPaginas)">
                            Siguiente
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>