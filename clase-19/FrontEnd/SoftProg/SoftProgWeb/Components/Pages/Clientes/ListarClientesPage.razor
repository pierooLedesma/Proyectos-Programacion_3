@page "/ListarClientes"
@attribute [Authorize(Roles = "Empleado,Admin")]

<div class="container py-3" data-testid="clients-list-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <TituloPaginaComponent Texto="Listar clientes" />
        <BotonVolverAtrasComponent />
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-semibold">Clientes registrados</h5>
            <button class="btn btn-primary" @onclick="RegistrarCliente" data-testid="client-create-btn">
                Registrar cliente
            </button>
        </div>
        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-sm-8 col-md-4">
                    <input class="form-control" data-testid="client-search-input" placeholder="Buscar por DNI"
                           @bind="DniBusqueda" />
                </div>
                <div class="col-sm-auto">
                    <button class="btn btn-outline-primary" @onclick="Buscar"
                            data-testid="client-search-btn">Buscar</button>
                </div>
                <div class="col-sm-auto">
                    <button class="btn btn-outline-secondary" @onclick="LimpiarBusqueda"
                            data-testid="client-clear-search-btn">Limpiar</button>
                </div>
            </div>

            <AlertaOperacionComponent Mensaje="@MensajeResultado" Exito="OperacionExitosa" CssAdicional="mb-3" />

            @if (Clientes.Count == 0)
            {
                <div class="alert alert-secondary border text-center mb-0" data-testid="client-empty-state">
                    <h6 class="fw-semibold">Sin registros por mostrar</h6>
                    <p class="mb-2">Aun no hay datos disponibles para esta seccion.</p>
                    <button class="btn btn-primary" @onclick="RegistrarCliente" data-testid="client-empty-create-btn">
                        Registrar cliente
                    </button>
                </div>
            }
            else
            {
                <div class="table-responsive border rounded">
                    <table class="table table-hover table-striped align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>DNI</th>
                                <th>Nombre</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cliente in ClientesPaginados)
                            {
                                <tr data-testid="@($"client-row-{cliente.Id}")">
                                    <td>@cliente.Id</td>
                                    <td>@cliente.Dni</td>
                                    <td>@($"{cliente.Nombre} {cliente.ApellidoPaterno}".Trim())</td>
                                    <td>
                                        <AccionesComponent Id="@cliente.Id" OnModificar="VerPerfil" EditarTexto="Ver perfil"
                                                           OnEliminar="Eliminar" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mt-3">
                    <small class="text-muted">Mostrando @InicioRegistro-@FinRegistro de @TotalRegistros registros</small>
                    <div class="btn-group" role="group" aria-label="Paginacion clientes">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="PaginaAnterior"
                                disabled="@(PaginaActual == 1)">
                            Anterior
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" disabled>
                            Pagina @PaginaActual de @TotalPaginas
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="PaginaSiguiente"
                                disabled="@(PaginaActual >= TotalPaginas)">
                            Siguiente
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>